# =========================================================
# 1. 硬件架构与唯一设备锁定 (解决 abt_asr3000 冲突报错)
# =========================================================
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_mt7981=y
CONFIG_TARGET_mediatek_mt7981_DEVICE_cmcc_rax3000m=y
# 必须显式关闭 ASR3000，否则 GitHub Actions 会因为设备 ID 重叠而崩溃
# CONFIG_TARGET_DEVICE_mediatek_mt7981_DEVICE_abt_asr3000 is not set

# =========================================================
# 2. HyperModem 核心组件 (Siriling 5G 仓库的灵魂)
# =========================================================
# 选定主插件及其依赖
CONFIG_PACKAGE_luci-app-hypermodem=y
CONFIG_PACKAGE_luci-i18n-hypermodem-zh-cn=y
CONFIG_PACKAGE_luci-app-modem=y 
CONFIG_PACKAGE_luci-app-usbmodem=y 
CONFIG_PACKAGE_sms-tool=y 
CONFIG_PACKAGE_modemband=y 

# 统一拨号器 (配合 diy-part2.sh 中的去重改名逻辑)
CONFIG_PACKAGE_quectel-cm=y

# =========================================================
# 3. 5G/USB 通用驱动底座 (解决“系统看不见模块”问题)
# =========================================================
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ncm=y
CONFIG_PACKAGE_kmod-usb-net-cdc-mbim=y
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan=y
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan-quectel=y
CONFIG_PACKAGE_kmod-usb-net-rndis=y

# 串口与通信驱动 (AT 指令交互必装)
CONFIG_PACKAGE_kmod-usb-serial=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_kmod-usb-serial-wwan=y
CONFIG_PACKAGE_kmod-usb-wdm=y

# 硬件层支持
CONFIG_PACKAGE_kmod-usb2=y


# =========================================================
# 4. NCM/ModemManager 协议桥梁 (确保接口菜单出现 NCM)
# =========================================================
CONFIG_PACKAGE_wwan=y 
CONFIG_PACKAGE_comgt=y 
CONFIG_PACKAGE_comgt-ncm=y 
CONFIG_PACKAGE_luci-proto-ncm=y 
CONFIG_PACKAGE_luci-proto-3g=y 

# --- ModemManager 增强链路 (HyperModem 的底层核心) ---
CONFIG_PACKAGE_modemmanager=y 
CONFIG_PACKAGE_luci-proto-modemmanager=y 
CONFIG_PACKAGE_libmbim=y 
CONFIG_PACKAGE_libqmi=y 

# =========================================================
# 5. HyperModem 必需的运行环境 (解决脚本运行报错/不拨号)
# =========================================================
# HyperModem 脚本深度依赖以下工具进行 JSON 解析和网络通信
CONFIG_PACKAGE_bash=y 
CONFIG_PACKAGE_curl=y 
CONFIG_PACKAGE_grep=y 
CONFIG_PACKAGE_jq=y 
CONFIG_PACKAGE_ca-bundle=y 

# --- Coreutils (防止拨号脚本因缺失基础命令而闪退) ---
CONFIG_PACKAGE_coreutils=y 
CONFIG_PACKAGE_coreutils-nohup=y 
CONFIG_PACKAGE_coreutils-base64=y 

# =========================================================
# 6. 内置三剑客 (利用 RAX3000M 128MB 闪存空间)
# =========================================================
# --- OpenClash ---
CONFIG_PACKAGE_luci-app-openclash=y 
CONFIG_PACKAGE_luci-i18n-openclash-zh-cn=y 

# --- SmartDNS ---
CONFIG_PACKAGE_smartdns=y 
CONFIG_PACKAGE_luci-app-smartdns=y 
CONFIG_PACKAGE_luci-i18n-smartdns-zh-cn=y 

# --- AdGuard Home (配合脚本仅安装插件界面) ---
CONFIG_PACKAGE_luci-app-adguardhome=y 

# =========================================================
# 9. 网络功能增强 (TTL 修改与流量分载)
# =========================================================
CONFIG_PACKAGE_kmod-ipt-ipopt=y
CONFIG_PACKAGE_iptables-mod-ipopt=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_usb-modeswitch=y
CONFIG_PACKAGE_usbutils=y
CONFIG_PACKAGE_lsusb=y
CONFIG_PACKAGE_kmod-usb3=y
# 允许修改只读分区 (如 Factory, U-Boot 等)
CONFIG_PACKAGE_kmod-mtd-rw=y

# 彻底移除 Ksmbd 网络共享
# CONFIG_PACKAGE_luci-app-ksmbd is not set
# CONFIG_PACKAGE_ksmbd-server is not set
# CONFIG_PACKAGE_luci-i18n-ksmbd-zh-cn is not set

# 彻底移除 USB 打印服务器
# CONFIG_PACKAGE_luci-app-usb-printer is not set
# CONFIG_PACKAGE_luci-i18n-usb-printer-zh-cn is not set
# 如果有 p910nd 也可以一并移除
# CONFIG_PACKAGE_luci-app-p910nd is not set

# 1. 强行关闭 Argon 主题及其配置插件
# CONFIG_PACKAGE_luci-theme-argon is not set
# CONFIG_PACKAGE_luci-app-argon-config is not set

# =========================================================
# 彻底移除 UPnP 与 NAT-PMP (节省空间与提升安全)
# =========================================================
# 移除 LuCI 界面插件
# CONFIG_PACKAGE_luci-app-upnp is not set
# CONFIG_PACKAGE_luci-i18n-upnp-zh-cn is not set

# 移除后台核心守护进程
# CONFIG_PACKAGE_miniupnpd is not set
