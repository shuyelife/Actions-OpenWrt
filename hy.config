# 2. USB 核心基础支持 (确保 USB 3.0 跑满)
# =========================================================
CONFIG_PACKAGE_kmod-usb-core=y 
CONFIG_PACKAGE_kmod-usb2=y 
CONFIG_PACKAGE_kmod-usb3=y 
CONFIG_PACKAGE_kmod-usb-storage=y

# 3. 5G NCM 网络协议驱动 (解决 NCM 链路挂载问题)
# =========================================================
CONFIG_PACKAGE_kmod-usb-net=y 
# 核心补齐：这是 NCM 的地基，不选它 cdc-ncm 容易 bind failure
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=y
# 5G NCM 专用驱动
CONFIG_PACKAGE_kmod-usb-net-cdc-ncm=y 
CONFIG_PACKAGE_kmod-usb-net-wwan=y

# 4. AT 指令串口驱动 (解决 usbserial_generic 占坑问题)
# =========================================================
CONFIG_PACKAGE_kmod-usb-serial=y 
# 核心补齐：专门针对移远/展锐优化的驱动，取代通用驱动识别 If 2-6
CONFIG_PACKAGE_kmod-usb-serial-option=y 
CONFIG_PACKAGE_kmod-usb-serial-wwan=y 
# 控制消息驱动
CONFIG_PACKAGE_kmod-usb-wdm=y

# 1. 5G 拨号与管理插件 (Siriling 方案)
# =========================================================
CONFIG_PACKAGE_luci-app-modem=y
CONFIG_PACKAGE_luci-i18n-modem-zh-cn=y
# 核心拨号工具：使用最新的 quectel-cm 适配 Kernel 6.6
CONFIG_PACKAGE_quectel-cm=y
CONFIG_PACKAGE_sms-tool=y
CONFIG_PACKAGE_luci-app-sms-tool-main=y
# 确保模式转换工具存在，防止 5G 模块被识识别为 U 盘
CONFIG_PACKAGE_usb-modeswitch=y
CONFIG_PACKAGE_usbutils=y

# 2. 三剑客：重装部队 (已补齐中文包)
# =========================================================
# OpenClash: 流量分流与加速
CONFIG_PACKAGE_luci-app-openclash=y
# SmartDNS: 防止 DNS 污染，提升起播速度
CONFIG_PACKAGE_luci-app-smartdns=y
CONFIG_PACKAGE_luci-i18n-smartdns-zh-cn=y
# AdGuardHome: 全局广告过滤与隐私保护
CONFIG_PACKAGE_luci-app-adguardhome=y
CONFIG_PACKAGE_luci-i18n-adguardhome-zh-cn=y

# 3. 24.10 (nftables) 特征伪装与网络优化 (核心补齐)
# =========================================================
# 补齐 nftables 核心模块：用于替代旧版 iptables 实现 TTL 修改与 NAT66
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-nft-bridge=y
# 流量分流与硬件加速支持
CONFIG_PACKAGE_kmod-shortcut-fe=y
CONFIG_PACKAGE_kmod-shortcut-fe-cm=y

# 4. 系统环境必备依赖 (确保三剑客脚本运行不报错)
# =========================================================
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_jq=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_coreutils=y
CONFIG_PACKAGE_coreutils-nohup=y
CONFIG_PACKAGE_libustream-openssl=y

# 1. 彻底移除干扰项 (预防串口抢占与拨号死锁)
# =========================================================
# 必须禁用：防止其抢占 /dev/ttyUSB 串口导致拨号失败 
# CONFIG_PACKAGE_modemmanager is not set
# CONFIG_PACKAGE_luci-proto-modemmanager is not set

# 禁用 USB Modem Server：防止与原生 NCM 协议产生逻辑冲突 
# CONFIG_PACKAGE_luci-app-usb-modem is not set

# 2. 极致瘦身：移除 5G 环境下的无用功 (腾出空间给三剑客) 
# =========================================================
# 移除 UPnP (5G 大局域网环境下完全无效) 
# CONFIG_PACKAGE_luci-app-upnp is not set
# CONFIG_PACKAGE_miniupnpd is not set

# 移除 Samba/网络共享 (节省约 5MB 空间) 
# CONFIG_PACKAGE_luci-app-ksmbd is not set
# CONFIG_PACKAGE_ksmbd-server is not set

# 移除 打印服务器
# CONFIG_PACKAGE_luci-app-usb-printer is not set
# CONFIG_PACKAGE_luci-app-p910nd is not set

# 3. 界面精简 (防止静态资源堆积)
# =========================================================
# 建议只保留默认主题，移除所有第三方重型主题 
# CONFIG_PACKAGE_luci-theme-argon is not set
# CONFIG_PACKAGE_luci-app-argon-config is not set

# 4. 高级维护与分区解锁 (老兵进阶专用)
# =========================================================
# 解锁只读分区：允许修改 Factory、U-Boot 等，方便底层维护 
CONFIG_PACKAGE_kmod-mtd-rw=y
# 强制指定单一设备，防止脚本提取多设备名导致镜像错误 
CONFIG_TARGET_MULTI_PROFILE=n
CONFIG_TARGET_PER_DEVICE_ROOTFS=n

# 5. 诊断工具补齐
# =========================================================
CONFIG_PACKAGE_pciutils=y
CONFIG_PACKAGE_lsusb=y
CONFIG_PACKAGE_nano=y
