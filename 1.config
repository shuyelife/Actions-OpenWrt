# --- 1. 设备架构设置 (RAX3000M NAND) ---
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_mt7981=y
CONFIG_TARGET_mediatek_mt7981_DEVICE_cmcc_rax3000m-nand=y

# --- 2. 系统核心与基础驱动 (必须内置) ---
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-serial=y
CONFIG_PACKAGE_usb-modeswitch=y
CONFIG_PACKAGE_usbutils=y

# --- 3. 5G/4G 通信协议驱动 (内置) ---
# RM500U 首选 MBIM 和 QMI，这里建议全设为 y 以防拨号失败
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan=y
CONFIG_PACKAGE_kmod-usb-net-cdc-mbim=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ncm=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=y
CONFIG_PACKAGE_kmod-usb-net-rndis=y
CONFIG_PACKAGE_kmod-usb-net-cdc-wdm=y

# 串口与 Quectel 模块支持
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_kmod-usb-serial-wwan=y
CONFIG_PACKAGE_kmod-usb-serial-qualcomm=y

# --- 4. HyperModem 及其核心依赖 (解决 Error 255 的关键) ---
# 必须加上这个拨号工具，否则 hy 插件会报依赖缺失
CONFIG_PACKAGE_quectel_cm_5g=y
CONFIG_PACKAGE_luci-app-hypermodem=y
CONFIG_PACKAGE_luci-i18n-hypermodem-zh-cn=y

# 短信与 AT 指令工具
CONFIG_PACKAGE_sms-tool=y
CONFIG_PACKAGE_luci-app-sms-tool=y

# 底层拨号引擎
CONFIG_PACKAGE_uqmi=y
CONFIG_PACKAGE_umbim=y
CONFIG_PACKAGE_comgt-ncm=y

# --- 5. 核心网络插件 (内置) ---
CONFIG_PACKAGE_luci-app-smartdns=y
CONFIG_PACKAGE_luci-i18n-smartdns-zh-cn=y

# --- 6. 模块化插件 (设为 M，节省 128MB NAND 空间) ---
# 编译时会生成 .ipk，但不直接塞进固件，防止固件过大
CONFIG_PACKAGE_luci-app-openclash=m
CONFIG_PACKAGE_luci-app-adguardhome=m

# --- 7. 基础环境与空间优化 ---
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_OPTIMIZE_SIZE=y

# 强制开启 LuCI 界面支持
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
