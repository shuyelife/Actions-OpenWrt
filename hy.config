# 1. 硬件架构确认（严格匹配源码 cmcc_rax3000m）
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_mt7981=y
CONFIG_TARGET_mediatek_mt7981_DEVICE_cmcc_rax3000m=y

# 2. 5G 增强插件 (HyperModem 版)
CONFIG_PACKAGE_luci-app-hypermodem=y
CONFIG_PACKAGE_luci-i18n-hypermodem-zh-cn=y
CONFIG_PACKAGE_quectel-cm=y
CONFIG_PACKAGE_sms-tool=y

# 3. 三剑客定制化设置
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_luci-app-smartdns=y
# AdGuard Home 设为模块化 (编译出 ipk，不占固件空间)
CONFIG_PACKAGE_luci-app-adguardhome=m

# 4. 5G/4G 核心驱动（RM500U, EC20, 移远全系）
CONFIG_PACKAGE_kmod-usb-net-cdc-ncm=y
CONFIG_PACKAGE_kmod-usb-net-cdc-mbim=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_kmod-usb-serial-wwan=y
CONFIG_PACKAGE_kmod-usb-serial-qualcomm=y

# 5. 手机/随身 WiFi/iPhone 热点共享驱动
CONFIG_PACKAGE_kmod-usb-net-rndis=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=y
CONFIG_PACKAGE_kmod-usb-net-ipheth=y

# 6. TTL 修改工具 (针对手机卡绕过检测)
CONFIG_PACKAGE_kmod-ipt-ipopt=y
CONFIG_PACKAGE_iptables-mod-ipopt=y

# 7. 辅助工具与调试
CONFIG_PACKAGE_usb-modeswitch=y
CONFIG_PACKAGE_usbutils=y
CONFIG_PACKAGE_lsusb=y
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_curl=y
