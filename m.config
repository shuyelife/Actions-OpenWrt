# 1. 硬件目标定义 (保持 RAX3000M 默认环境)
# =========================================================
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_cmcc_rax3000m=y

# 2. USB 3.0 深度优化 (确保 5G 高速吞吐)
# =========================================================
CONFIG_PACKAGE_kmod-usb-core=y 
CONFIG_PACKAGE_kmod-usb2=y 
CONFIG_PACKAGE_kmod-usb3=y 
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-extras=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y

# 3. 万能网络协议驱动栈 (NCM/MBIM/RNDIS/ECM/QMI)
# =========================================================
CONFIG_PACKAGE_kmod-usb-net=y 
# 基础框架
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=y
CONFIG_PACKAGE_kmod-usb-net-wwan=y
# 5G NCM 协议 (针对 RM500U / 展锐)
CONFIG_PACKAGE_kmod-usb-net-cdc-ncm=y 
# 5G MBIM 协议 (针对 移远 / 高通 / 现代 5G 模块)
CONFIG_PACKAGE_kmod-usb-net-cdc-mbim=y 
# 随身 WiFi / 手机 USB 共享专用 (RNDIS / ECM)
CONFIG_PACKAGE_kmod-usb-net-rndis=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ecm=y
# 经典 QMI 协议 (针对 旧款高通 4G/5G 模块)
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan=y

# 4. 串口控制通道 (解决 AT 指令下发问题)
# =========================================================
CONFIG_PACKAGE_kmod-usb-serial=y 
CONFIG_PACKAGE_kmod-usb-serial-option=y 
CONFIG_PACKAGE_kmod-usb-serial-wwan=y 
CONFIG_PACKAGE_kmod-usb-wdm=y
CONFIG_PACKAGE_usb-modeswitch=y

# 1. Siriling 5G 管理全家桶 (Modem (New) 核心)
# =========================================================
# 核心管理界面：支持信号监控、AT 调试与小区锁定
CONFIG_PACKAGE_luci-app-modem=y
CONFIG_PACKAGE_luci-i18n-modem-zh-cn=y
# 频段锁定工具：专门针对 5G NR 频段优化
CONFIG_PACKAGE_luci-app-modemband=y
CONFIG_PACKAGE_luci-i18n-modemband-zh-cn=y

# 2. 核心拨号工具与协议桥梁 (确保 MBIM/NCM 都能拨通)
# =========================================================
# 移远/展锐官方高性能拨号工具 (支持 quectel-cm 模式)
CONFIG_PACKAGE_quectel-cm=y
# 系统原生协议插件 (作为备选，增加全能性)
CONFIG_PACKAGE_luci-proto-ncm=y
CONFIG_PACKAGE_luci-proto-mbim=y
# 基础依赖
CONFIG_PACKAGE_wwan=y
CONFIG_PACKAGE_comgt=y
CONFIG_PACKAGE_comgt-ncm=y

# 3. 短信与串口调试工具 (老兵必玩)
# =========================================================
# 短信核心工具：支持网页端查看、发送短信
CONFIG_PACKAGE_sms-tool=y
CONFIG_PACKAGE_luci-app-sms-tool-main=y
# 串口调试神器：如果你想进 SSH 用 AT 指令，这个比 echo 更好用
CONFIG_PACKAGE_minicom=y

# 4. 环境依赖补齐 (确保 5G 脚本运行不报错)
# =========================================================
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_jq=y
CONFIG_PACKAGE_coreutils=y
CONFIG_PACKAGE_coreutils-nohup=y
CONFIG_PACKAGE_usb-modeswitch=y

# 1. 三剑客：DNS 与 流量控制中枢 (已补齐中文与核心依赖)
# =========================================================
# AdGuardHome: 负责前端广告拦截与 DNS 审计
CONFIG_PACKAGE_luci-app-adguardhome=y
CONFIG_PACKAGE_luci-i18n-adguardhome-zh-cn=y

# SmartDNS: 负责 DNS 并发查询与 IP 优选
CONFIG_PACKAGE_luci-app-smartdns=y 
CONFIG_PACKAGE_luci-i18n-smartdns-zh-cn=y

# OpenClash: 负责流量出口控制与分流
CONFIG_PACKAGE_luci-app-openclash=y

# 2. Kernel 6.6 / Firewall 4 (nftables) 性能补丁
# =========================================================
# 必选：补齐 nftables 核心 NAT 与 转发模块 (TTL 修改与三剑客兼容的基础)
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-nft-bridge=y
CONFIG_PACKAGE_kmod-nft-netdev=y

# 3. 5G 高速转发优化 (Shortcut-FE / PPE 加速)
# =========================================================
# 硬件流量分流：降低 5G 满速下载时的 CPU 软中断
CONFIG_PACKAGE_kmod-shortcut-fe=y
CONFIG_PACKAGE_kmod-shortcut-fe-cm=y
# 联发科硬件加速引擎 (PPE) 支持
CONFIG_PACKAGE_kmod-nft-offload=y

# 4. 系统瘦身与垃圾剔除 (腾出空间给三剑客规则库)
# =========================================================
# 彻底移除干扰项：防止 ModemManager 抢占串口
# CONFIG_PACKAGE_modemmanager is not set
# CONFIG_PACKAGE_luci-proto-modemmanager is not set

# 移除 Samba、打印服务等 5G 环境冗余功能 [cite: 2]
# CONFIG_PACKAGE_luci-app-ksmbd is not set
# CONFIG_PACKAGE_luci-app-usb-printer is not set 

# 5. 高级权限与分区解锁 (解锁 128MB 全潜力)
# =========================================================
# 解锁只读分区：允许修改 Factory、U-Boot 等，方便底层维护 
CONFIG_PACKAGE_kmod-mtd-rw=y 
# 移除重型主题：保持系统极度纯净，确保 flash 不溢出 
# CONFIG_PACKAGE_luci-theme-argon is not set
