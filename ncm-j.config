# 1. 硬件目标定义 (RAX3000M 专用)
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_cmcc_rax3000m=y

# 2. 物理强杀短信组件 (预防文件冲突的关键)
# 显式禁用旧版与新版短信应用及其所有后端依赖
# CONFIG_PACKAGE_luci-app-qmodem-sms is not set
# CONFIG_PACKAGE_sms-tool is not set
# CONFIG_PACKAGE_sms-forwarder is not set
# CONFIG_PACKAGE_luci-app-qmodem-next-sms is not set
# CONFIG_PACKAGE_sms-tool_q is not set
# CONFIG_PACKAGE_sms-forwarder-next is not set

# CONFIG_PACKAGE_kmod-qmi_wwan_f is not set
# CONFIG_PACKAGE_kmod-qmi_wwan_q is not set
# CONFIG_PACKAGE_kmod-qmi_wwan_s is not set
# CONFIG_PACKAGE_kmod-pcie_mhi is not set

# 3. QModem-Next 核心纯净版 (不含短信插件)
CONFIG_PACKAGE_luci-app-qmodem-next=y
CONFIG_PACKAGE_qmodem=y
CONFIG_PACKAGE_luci-app-qmodem-hc=y
CONFIG_PACKAGE_luci-app-qmodem-stats=y

# 4. 核心解析与网络发现依赖
CONFIG_PACKAGE_jq=y
CONFIG_PACKAGE_ndisc6=y

# 5. RAX3000M 底座 USB 控制器驱动 (满速不掉线基础)
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb-xhci-mtk=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb2=y

# 6. 5G 模组底层通讯与控制 (AT 指令与模式切换)
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_kmod-usb-serial-wwan=y
CONFIG_PACKAGE_usb-modeswitch=y
CONFIG_PACKAGE_comgt=y
CONFIG_PACKAGE_comgt-ncm=y
CONFIG_PACKAGE_wwan=y

# 7. USB 网络层数据驱动 (全协议制备)
CONFIG_PACKAGE_kmod-usb-net-cdc-ncm=y
CONFIG_PACKAGE_kmod-usb-net-cdc-mbim=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=y
CONFIG_PACKAGE_kmod-usb-net-rndis=y
CONFIG_PACKAGE_kmod-usb-net-cdc-wdm=y

# 8. 网络物理层基石与 USB 识别库
CONFIG_PACKAGE_kmod-mii=y
CONFIG_PACKAGE_usbutils=y
CONFIG_PACKAGE_usbids=y

# 9. 5G IPv6 核心与 NAT6 转换 (确保 5G 下发 IPv6 正常上网)
CONFIG_PACKAGE_kmod-ipt-nat6=y
CONFIG_PACKAGE_ip6tables-mod-nat=y
CONFIG_PACKAGE_kmod-ip6tables=y

# 10. “三剑客”底层流量劫持与追踪依赖 (OpenClash 透明代理必备)
CONFIG_PACKAGE_kmod-ipt-tproxy=y
CONFIG_PACKAGE_kmod-ipt-extra=y
CONFIG_PACKAGE_iptables-mod-tproxy=y
CONFIG_PACKAGE_iptables-mod-extra=y
CONFIG_PACKAGE_iptables-mod-conntrack-extra=y

# 11. 高级脚本运行环境 (保障重型插件后台稳定运行)
CONFIG_PACKAGE_coreutils-nohup=y
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_curl=y

# 2. 三剑客：重装部队 (已补齐中文包)
# =========================================================
# OpenClash: 流量分流与加速
CONFIG_PACKAGE_luci-app-openclash=y
# SmartDNS: 防止 DNS 污染，提升起播速度
CONFIG_PACKAGE_luci-app-smartdns=y
CONFIG_PACKAGE_luci-i18n-smartdns-zh-cn=y
# AdGuardHome: 全局广告过滤与隐私保护
CONFIG_PACKAGE_luci-app-adguardhome=y
CONFIG_PACKAGE_luci-i18n-adguardhome-zh-cn=y

# 13. 核心性能优化与硬件加速 (榨干 MT7981 与 5G 带宽)
CONFIG_PACKAGE_kmod-mtk-offload=y
CONFIG_PACKAGE_kmod-shortcut-fe=y
CONFIG_PACKAGE_kmod-shortcut-fe-cm=y
CONFIG_KERNEL_TCP_CONG_BBR=y
CONFIG_KERNEL_TCP_CONG_ADVANCED=y

# 14. 内存管理与分区解锁 (保护 Flash，突破只读限制)
CONFIG_PACKAGE_kmod-zram=y
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_kmod-mtd-rw=y

# 15. 系统维护与极客调试工具箱
CONFIG_PACKAGE_iftop=y
CONFIG_PACKAGE_picocom=y
CONFIG_PACKAGE_pciutils=y
CONFIG_PACKAGE_lsusb=y
CONFIG_PACKAGE_nano=y

# 16. 彻底禁用臃肿与无关组件 (极致瘦身，杜绝多余进程抢占资源)
# CONFIG_PACKAGE_modemmanager is not set
# CONFIG_PACKAGE_luci-proto-modemmanager is not set
# CONFIG_PACKAGE_luci-app-usb-modem is not set
# CONFIG_PACKAGE_

