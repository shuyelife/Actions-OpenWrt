CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_mt7981=y
CONFIG_TARGET_mediatek_mt7981_DEVICE_cmcc_rax3000m=y
# CONFIG_TARGET_DEVICE_mediatek_mt7981_DEVICE_abt_asr3000 is not set

# =========================================================
# 2. 5G NCM 核心驱动 (仅保留 NCM 路径，移除 QMI/MBIM 干扰)
# =========================================================
# USB 核心支持
CONFIG_PACKAGE_kmod-usb-core=y 
CONFIG_PACKAGE_kmod-usb2=y 
CONFIG_PACKAGE_kmod-usb3=y 

# NCM 网络协议驱动 (RM500U 拨号核心)
CONFIG_PACKAGE_kmod-usb-net=y 
CONFIG_PACKAGE_kmod-usb-net-cdc-ncm=y 
CONFIG_PACKAGE_kmod-usb-net-wwan=y

# AT 指令通道驱动 (用于下发拨号指令)
CONFIG_PACKAGE_kmod-usb-serial=y 
CONFIG_PACKAGE_kmod-usb-serial-option=y 
CONFIG_PACKAGE_kmod-usb-serial-wwan=y 
CONFIG_PACKAGE_kmod-usb-wdm=y 

# =========================================================
# 3. 网络功能增强 (TTL 修改，确保手机卡上网不被拦截)
# =========================================================
CONFIG_PACKAGE_kmod-ipt-ipopt=y 
CONFIG_PACKAGE_iptables-mod-ipopt=y 

# =========================================================
# 4. USB 模式转换与识别 (确保模块不被识别为 U盘)
# =========================================================
CONFIG_PACKAGE_usb-modeswitch=y 
CONFIG_PACKAGE_usbutils=y 
CONFIG_PACKAGE_lsusb=y

# =========================================================
# 4. 5G 拨号协议桥梁 (确保界面出现 NCM 选项)
# =========================================================
CONFIG_PACKAGE_wwan=y 
CONFIG_PACKAGE_chat=y 
CONFIG_PACKAGE_comgt=y 
CONFIG_PACKAGE_comgt-ncm=y 
CONFIG_PACKAGE_luci-proto-ncm=y 

# =========================================================
# 5. 5G 管理插件 (Siriling 仓库核心)
# =========================================================
CONFIG_PACKAGE_luci-app-modem=y 
CONFIG_PACKAGE_luci-i18n-modem-zh-cn=y 
CONFIG_PACKAGE_sms-tool=y 
CONFIG_PACKAGE_quectel-cm=y 

# =========================================================
# 6. 核心环境依赖 (确保拨号脚本能跑通)
# =========================================================
CONFIG_PACKAGE_bash=y 
CONFIG_PACKAGE_curl=y 
CONFIG_PACKAGE_jq=y 
CONFIG_PACKAGE_coreutils=y 
CONFIG_PACKAGE_coreutils-nohup=y 

# =========================================================
# 7. 排除干扰项 (三剑客与 ModemManager 全部剔除)
# =========================================================
# --- 彻底移除三剑客 ---
# CONFIG_PACKAGE_luci-app-openclash is not set
# CONFIG_PACKAGE_luci-app-smartdns is not set
# CONFIG_PACKAGE_luci-app-adguardhome is not set

# --- 彻底移除 ModemManager (防止抢占端口) ---
# CONFIG_PACKAGE_modemmanager is not set 
# CONFIG_PACKAGE_luci-proto-modemmanager is not set

# =========================================================
# 彻底移除无用功能 (极简 5G 专用)
# =========================================================

# 1. 移除 UPnP 与 NAT-PMP (你刚才截图里那个)
# CONFIG_PACKAGE_luci-app-upnp is not set
# CONFIG_PACKAGE_miniupnpd is not set

# 2. 移除 USB Modem Server (防止干扰 NCM 拨号)
# CONFIG_PACKAGE_luci-app-usb-modem is not set

# 3. 移除多余的旧式拨号工具 (仅保留 quectel-cm)
# CONFIG_PACKAGE_modemmanager is not set
# CONFIG_PACKAGE_luci-proto-modemmanager is not set
